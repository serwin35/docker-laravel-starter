# =============================================================================
# Laravel Docker Starter — Environment Variables
#
# Copy to .env and fill in values:
#   cp .env.example .env
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ── Docker ────────────────────────────────────────────────────────────────────
APP_PORT=80
# Your host UID/GID (run: id -u && id -g)
UID=1000
GID=1000

# ── Database ──────────────────────────────────────────────────────────────────
# Choose: mysql | pgsql
# Start with matching profile: COMPOSE_PROFILES=mysql make up
DB_CONNECTION=mysql
DB_HOST=mysql         # or: pgsql
DB_PORT=3306          # or: 5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=redissecret
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ── Mail (Mailpit for dev) ────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_UI_PORT=8025

# ── Vite / NPM ────────────────────────────────────────────────────────────────
NPM_PORT=3000
VITE_PORT=5173

# ── MinIO (local S3-compatible storage) — requires profile: minio ─────────────
# Start with: COMPOSE_PROFILES=minio,mysql make up
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Laravel S3 config pointing to local MinIO
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=laravel
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# ── CI/CD (set in GitHub Environment vars/secrets) ────────────────────────────
# GITHUB_REPOSITORY=your-org/your-app   # auto-set by GitHub Actions
# IMAGE_TAG=latest                       # set per deployment
